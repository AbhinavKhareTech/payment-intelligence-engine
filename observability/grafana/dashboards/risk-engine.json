{
  "dashboard": {
    "id": null,
    "uid": "risk-engine",
    "title": "Payment Intelligence Engine",
    "tags": ["payments", "risk", "fraud"],
    "timezone": "browser",
    "refresh": "5s",
    "panels": [
      {
        "title": "Decision Distribution",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum by (decision) (risk_decision_total)",
            "legendFormat": "{{decision}}"
          }
        ]
      },
      {
        "title": "E2E Pipeline Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 10, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(pipeline_e2e_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(pipeline_e2e_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(pipeline_e2e_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "GenAI Scoring Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(risk_scoring_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(risk_scoring_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Transactions Ingested (rate/s)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(pipeline_transactions_ingested_total[5m])"
          }
        ]
      },
      {
        "title": "GenAI Success vs Fallback",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 10, "x": 4, "y": 8 },
        "targets": [
          {
            "expr": "rate(risk_scoring_success_total[5m])",
            "legendFormat": "GenAI Success"
          },
          {
            "expr": "rate(risk_scoring_fallback_total[5m])",
            "legendFormat": "Deterministic Fallback"
          }
        ]
      },
      {
        "title": "DLQ Messages",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 14, "y": 8 },
        "targets": [
          {
            "expr": "pipeline_transactions_dlq_total",
            "legendFormat": "DLQ Count"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 20 }
              ]
            }
          }
        }
      },
      {
        "title": "Circuit Breaker State",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "resilience4j_circuitbreaker_state{name=\"genai-scoring\"}",
            "legendFormat": "{{name}}"
          }
        ]
      }
    ]
  }
}
